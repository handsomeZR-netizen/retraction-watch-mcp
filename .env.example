# Copy to .env (gitignored) before running `docker compose up -d`.
# Generate hex secrets with: openssl rand -hex 32

# --- Required in production ---
RW_SESSION_SECRET=replace-with-32-byte-hex
RW_BASE_URL=http://your-server-ip-or-domain

# --- Strongly recommended ---
# Encrypts user-stored LLM API keys at rest. Once set, do NOT change or
# existing encrypted records become unreadable.
RW_DATA_KEY=replace-with-32-byte-hex

# --- Host port mapping (docker-compose.yml reads this) ---
# 80 for direct HTTP, 3210 for dev/behind reverse proxy
RW_HOST_PORT=80

# --- Initial admin (only used by `npm run seed-admin -w @rw/web`) ---
# Run the seed once from the host after `npm ci`, with the container stopped.
# These values are not read by the running container.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# --- Optional: SMTP for email verification / password reset ---
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# SMTP_FROM=RW Screen <noreply@example.com>

# --- Optional: OAuth providers ---
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# --- Optional: LLM (DeepSeek-compatible) for reference extraction ---
# RW_LLM_API_KEY=
# RW_LLM_BASE_URL=https://api.deepseek.com/v1
# RW_LLM_MODEL=deepseek-v4-flash

# --- Optional: HSTS (only meaningful behind HTTPS) ---
# RW_HSTS_INCLUDE_SUBDOMAINS=1
# RW_HSTS_PRELOAD=1
