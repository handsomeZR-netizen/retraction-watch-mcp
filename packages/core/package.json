{
  "name": "@rw/core",
  "version": "0.4.9",
  "type": "module",
  "description": "Retraction Watch screening engine: matcher, normalize, repository, policy.",
  "license": "MIT",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/lib.js",
    "./matcher": "./dist/matching/matcher.js",
    "./normalize": "./dist/matching/normalize.js",
    "./repository": "./dist/data/repository.js",
    "./policy": "./dist/policy.js",
    "./output": "./dist/output.js",
    "./types": "./dist/data/types.js",
    "./config": "./dist/config.js"
  },
  "bin": {
    "rw-mcp": "./dist/index.js",
    "rw-import": "./dist/cli/import.js",
    "rw-query": "./dist/cli/query.js",
    "rw-doctor": "./dist/cli/doctor.js"
  },
  "files": [
    "dist/",
    "policies/"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "import": "node dist/cli/import.js",
    "query": "node dist/cli/query.js",
    "doctor": "node dist/cli/doctor.js",
    "mcp": "node dist/index.js",
    "dev:import": "tsx src/cli/import.ts",
    "dev:query": "tsx src/cli/query.ts",
    "dev:mcp": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "11.7.0",
    "csv-parse": "5.6.0",
    "pinyin-pro": "3.27.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "25.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  }
}
